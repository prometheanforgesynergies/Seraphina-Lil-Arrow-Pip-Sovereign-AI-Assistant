{
  "manifest_version": 3,
  "name": "Lil Arrow Pip — Desktop Bridge",
  "version": "2.0.0",
  "description": "Connects your browser to Lil Arrow Pip desktop droid. Full context awareness for your sovereign AI assistant.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lil Pip Browser Bridge",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
